# Transport: "smallwebrtc" (default) or "daily"
VITE_TRANSPORT=smallwebrtc

# Bot start URL. Default: http://localhost:7860/start
# Point this at your deployed Pipecat Cloud endpoint or a tunnel.
# VITE_BOT_START_URL=http://localhost:7860/start

# Optional: bearer token sent on the /start request when a deployment
# requires authentication (e.g. Pipecat Cloud public API key).
# VITE_BOT_START_PUBLIC_API_KEY=
