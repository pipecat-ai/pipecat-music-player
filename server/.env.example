# LLM provider for the voice + UI worker LLMs.
# One of: openai (default) | cerebras.
# To use cerebras, install the corresponding pipecat extra
# (e.g. `uv add 'pipecat-ai[cerebras]'`) and set its API key below.
LLM_PROVIDER=openai

OPENAI_API_KEY=
OPENAI_MODEL=

# CEREBRAS_API_KEY=
# CEREBRAS_MODEL=

# `descriptions.py` (catalog blurbs + Q&A) always uses the OpenAI SDK
# directly, so OPENAI_API_KEY is required regardless of LLM_PROVIDER.

SONIOX_API_KEY=
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
DAILY_API_KEY=
