# Pipecat Cloud's CLI uses Python's fnmatch to match each path component
# against these patterns, so directory entries need to be plain names
# (no trailing slash). "foo/" becomes a literal pattern that never
# matches a bare "foo", which is why trailing-slash entries silently
# do nothing in cloud builds.

# Python
__pycache__
*.py[cod]
*.pyo
*.pyd
*.egg-info
.venv
venv
env
ENV

# Tool caches
.ruff_cache
.pytest_cache
.mypy_cache

# Secrets (lockfile + pyproject are bind-mounted for uv sync; anything
# else that carries creds stays out of the image)
.env
.env.local

# VCS
.git
.gitignore

# Editor
.idea
.vscode

# OS
.DS_Store
Thumbs.db

# Logs
*.log
